{
  "name": "bgi-content-studio",
  "private": true,
  "version": "1.0.2",
  "main": "electron/main.cjs",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:server": "node server/scraper.mjs",
    "dev:vps": "node server/vps_server.mjs",
    "dev:all": "npm-run-all --parallel dev dev:server dev:vps",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "electron:dev": "concurrently \"vite\" \"node server/scraper.mjs\" \"wait-on http://localhost:5173 && cross-env NODE_ENV=development electron .\"",
    "electron:build": "npm run build && electron-builder build --win --publish never",
    "electron:build:prod": "npm run build && electron-builder build --win --publish always"
  },
  "dependencies": {
    "adm-zip": "^0.5.17",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^1.18.0",
    "node-fetch": "^3.3.2",
    "pg": "^8.22.0",
    "pg-int8": "^1.0.1",
    "pg-pool": "^3.14.0",
    "pg-protocol": "^1.15.0",
    "pg-types": "^2.2.0",
    "playwright": "^1.60.0",
    "playwright-core": "^1.60.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@pandacss/dev": "^1.11.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^32.2.0",
    "electron-builder": "^25.1.8",
    "electron-packager": "^17.1.2",
    "electron-updater": "^6.8.9",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "npm-run-all": "^4.1.5",
    "png-to-ico": "^3.0.1",
    "semver": "^7.8.5",
    "sharp": "^0.35.2",
    "vite": "^8.0.12",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.bgi.contentstudio",
    "productName": "BGI Content Studio",
    "copyright": "Copyright © 2024 BGI",
    "asar": false,
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "server/**/*",
      "node_modules/**/*",
      "electron/**/*",
      "package.json",
      "package-lock.json"
    ],
    "extraResources": [
      {
        "from": "server",
        "to": "server",
        "filter": [
          "**/*",
          "!**/*.map"
        ]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "public/icon.ico",
      "artifactName": "${productName}-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "BGI Content Studio",
      "installerIcon": "public/icon.ico",
      "uninstallerIcon": "public/icon.ico",
      "installerHeaderIcon": "public/icon.ico",
      "deleteAppDataOnUninstall": false,
      "runAfterFinish": true
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "icon": "public/icon.png",
      "category": "Development"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "icon": "public/icon.icns",
      "category": "public.app-category.developer-tools"
    }
  }
}
